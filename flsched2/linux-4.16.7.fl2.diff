< long sched_group_rt_period(struct task_group *tg)
< {
< 	u64 rt_period_us;
< 
< 	rt_period_us = ktime_to_ns(tg->rt_bandwidth.rt_period);
< 	do_div(rt_period_us, NSEC_PER_USEC);
< 	return rt_period_us;
